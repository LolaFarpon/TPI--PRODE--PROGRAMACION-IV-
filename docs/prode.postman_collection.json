  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Registrar usuario (USER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "registro"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"tester\",\n  \"email\": \"tester@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Registrar usuario ADMIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "registro"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"adminprode\",\n  \"email\": \"admin@prode.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Despues de registrar este usuario, cambiar su rol a ADMIN.",
                  "// En pgAdmin (o psql) correr:",
                  "// UPDATE usuarios SET rol = 'ADMIN' WHERE email = 'admin@prode.com';",
                  "// Despues hacer el Login ADMIN de nuevo para que el token lleve el rol ADMIN."
                ]
              }
            }
          ]
        },
        {
          "name": "Login ADMIN - guarda token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@prode.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.datos && json.datos.token) {",
                  "    pm.collectionVariables.set('tokenAdmin', json.datos.token);",
                  "    console.log('Token admin guardado');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login USER - guarda token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tester@test.com\",\n  \"password\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.datos && json.datos.token) {",
                  "    pm.collectionVariables.set('tokenUser', json.datos.token);",
                  "    console.log('Token user guardado');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
