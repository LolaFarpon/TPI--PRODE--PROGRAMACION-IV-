        {
          "name": "2) Crear equipo local",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/equipos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "equipos"
              ]
            },
            "description": "Guarda el id en {{equipoLocalId}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Local {{rnd}}\"\n}",
