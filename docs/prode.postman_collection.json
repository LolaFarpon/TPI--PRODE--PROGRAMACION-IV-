      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/registro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "registro"
              ]
            },
            "description": "Público. Crea un usuario con rol USER. Email/usuario repetido -> 409.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreUsuario\": \"nuevo_user\",\n  \"email\": \"nuevo@prode.com\",\n  \"password\": \"clave123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        },
        {
          "name": "Login (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Público. Devuelve el token y lo guarda en {{token}}.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@prode.com\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Guarda el token del login en la variable {{token}} para usarlo solo",
                  "const res = pm.response.json();",
                  "if (res && res.datos && res.datos.token) {",
                  "  pm.collectionVariables.set('token', res.datos.token);",
                  "  pm.collectionVariables.set('rol', res.datos.rol);",
                  "  console.log('Token guardado. Rol:', res.datos.rol);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (USER - lu)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
