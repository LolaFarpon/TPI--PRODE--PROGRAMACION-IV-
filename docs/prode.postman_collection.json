{
  "info": {
    "name": "PRODE API - TPI Programación IV (UTN FRVM)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "tokenAdmin",
      "value": ""
    },
    {
      "key": "tokenUser",
      "value": ""
    }
